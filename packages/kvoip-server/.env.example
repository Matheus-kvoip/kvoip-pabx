PORT=3001
API_PREFIX=api
API_NAME=kvoip-server
API_VERSION=0.1.0
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=kvoip-dev-secret-change-me
JWT_EXPIRES_IN=8h
AUTH_EMAIL=admin@kvoip.com.br
AUTH_PASSWORD=kvoip123
AUTH_NAME=Administrador
NODE_ENV=development
PBX_URL=http://127.0.0.1:8080
PBX_ENABLED=true
CDR_WEBHOOK_SECRET=kvoip-cdr-dev
# sqlite (local sem Docker) | postgres (produção / compose)
DB_TYPE=sqlite
SQLITE_PATH=data/kvoip.sqlite
DATABASE_URL=postgres://kvoip:kvoip@127.0.0.1:5432/kvoip
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=kvoip
DB_PASSWORD=kvoip
DB_NAME=kvoip
# postgres: DB_SYNC=false + DB_MIGRATIONS_RUN=true
DB_SYNC=true
DB_MIGRATIONS_RUN=false
DB_LOGGING=false
