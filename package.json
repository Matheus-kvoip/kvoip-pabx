{
  "name": "kvoip",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma PABX Kvoip",
  "workspaces": [
    "packages/kvoip-shared",
    "packages/kvoip-server",
    "packages/kvoip-front"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:server": "npm run start:dev -w kvoip-server",
    "dev:front": "npm run dev -w kvoip-front",
    "dev:pbx": "npm run pbx:run",
    "softphone:create": "cd packages/kvoip-softphone && flutter create . --project-name kvoip_softphone --org com.kvoip",
    "softphone:get": "cd packages/kvoip-softphone && flutter pub get",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "pbx:run": "cd packages/kvoip-pbx && go run ./cmd/kvoip-pbx",
    "pbx:build": "cd packages/kvoip-pbx && go build -o bin/kvoip-pbx ./cmd/kvoip-pbx",
    "pbx:test": "cd packages/kvoip-pbx && go test ./...",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "typeorm": "0.3.21"
  },
  "dependencies": {
    "typeorm": "0.3.21"
  }
}
